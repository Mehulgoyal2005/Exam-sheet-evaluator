# ─── SERVER ───────────────────────────────────────────────
# Port the Express server listens on
PORT=5000

# ─── DATABASE ─────────────────────────────────────────────
# When running locally without Docker:
# mongodb://localhost:27017/exameval
# When running with Docker Compose:
# mongodb://mongo:27017/exameval
MONGODB_URI=mongodb+srv://youruser:yourpassword@yourcluster.mongodb.net/exameval?retryWrites=true&w=majority

# ─── AUTHENTICATION ───────────────────────────────────────
# Any long random string - never share this with anyone
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ─── CLOUDINARY ───────────────────────────────────────────
# Get from: cloudinary.com → Dashboard → Product Environment Credentials
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── GROQ ─────────────────────────────────────────────────
# Get from: console.groq.com → API Keys → Create API Key
# Key starts with gsk_
GROQ_API_KEY=gsk_your_key_here

# ─── REDIS ────────────────────────────────────────────────
# When running locally without Docker:
# redis://localhost:6379
# When running with Docker Compose:
# redis://redis:6379
# When using Upstash cloud Redis:
# rediss://default:yourpassword@your-db.upstash.io:6379
REDIS_URL=rediss://default:yourpassword@your-db.upstash.io:6379

# ─── PYTHON OCR SERVICE ───────────────────────────────────
# When running locally without Docker:
# http://localhost:8000
# When running with Docker Compose:
# http://ocr-service:8000
OCR_SERVICE_URL=http://localhost:8000

# ─── CLIENT ───────────────────────────────────────────────
# URL where React frontend runs
# In development this is always:
CLIENT_URL=http://localhost:5173